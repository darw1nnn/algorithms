#include <iostream>
#include <cstdlib>
#include <ctime>

using namespace std;

int gcd(int a, int b) {
    while (b) {
        a %= b;
        swap(a, b);
    }
    return a;
}

long long power(long long base, long long exp, long long mod) {
    long long res = 1;
    base %= mod;

    while (exp > 0) {
        if (exp % 2 == 1)
            res = (res * base) % mod;

        base = (base * base) % mod;
        exp /= 2;
    }

    return res;
}

bool isPrime(int n) {
    if (n < 2) return false;

    for (int i = 2; i * i <= n; i++) {
        if (n % i == 0)
            return false;
    }

    return true;
}

int generatePrime() {
    while (true) {
        int num = rand() % 50 + 10; // 10–59 аралығы

        if (isPrime(num))
            return num;
    }
}

int main() {

    srand(time(0));

    int p = generatePrime();
    int q = generatePrime();

    while (p == q) {
        q = generatePrime();
    }

    int n = p * q;
    int fi = (p - 1) * (q - 1);

    int e;
    while (true) {
        e = rand() % (fi - 2) + 2;

        if (gcd(e, fi) == 1)
            break;
    }

    int d = 0;
    int k = 1;

    while (true) {
        if ((k * fi + 1) % e == 0) {
            d = (k * fi + 1) / e;
            break;
        }
        k++;
    }

    cout << "p = " << p << endl;
    cout << "q = " << q << endl;

    cout << "public key (e, n) = (" << e << ", " << n << ")" << endl;
    cout << "private key d = " << d << endl;

    int m = rand() % 20 + 1;
    cout << "message m = " << m << endl;

    long long c = power(m, e, n);
    cout << "encrypted = " << c << endl;

    long long decrypt = power(c, d, n);
    cout << "decrypted = " << decrypt << endl;

    if (m == decrypt)
        cout << "success" << endl;

    return 0;
}
